# ===========================
# BOT DISCORD
# ===========================
DISCORD_TOKEN=twoj_token_bota_discord_tutaj
DISCORD_CLIENT_ID=id_aplikacji_discord
DISCORD_GUILD_ID=id_twojego_serwera_discord
DISCORD_LOG_CHANNEL_ID=id_kanalu_logow_discord
DISCORD_DUTY_CHANNEL_ID=id_kanalu_sluzby
DISCORD_CV_CHANNEL_ID=id_kanalu_cv
DISCORD_PROMOTIONS_CHANNEL_ID=id_kanalu_awansow
DISCORD_DISMISSALS_CHANNEL_ID=id_kanalu_zwolnien
DISCORD_REQUESTS_CHANNEL_ID=id_kanalu_wnioskow_o_awans

# ===========================
# HTTP API BOTA
# ===========================
BOT_PORT=3001

# Sekret musi być IDENTYCZNY jak BOT_API_SECRET w backend/.env (min. 32 znaki)
BOT_API_SECRET=sekret_komunikacji_backend_bot_min_32znaki_xyz

# URL backendu (gdy bot na innym hostingu niż backend, wpisz publiczny URL)
BACKEND_URL=https://api.twoja-domena.com

# ===========================
# ROLE DISCORD (ID ról stopni)
# ===========================
DISCORD_ROLE_KADET=
DISCORD_ROLE_DROGOWKA=
DISCORD_ROLE_SIERZANT=
DISCORD_ROLE_ZSZEF=
DISCORD_ROLE_SZEF=
